# ── Meta App credentials ─────────────────────────────────────────────────────
# From Meta App dashboard → App Settings → Basic
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# ── Embedded Signup (Tech Provider — requires Meta approval) ─────────────────
# From Meta App Dashboard → WhatsApp → Embedded Signup → Configuration ID
META_CONFIG_ID=your_embedded_signup_config_id_here
# The public URL of THIS gateway service (auto-registered as webhook for each tenant WABA)
META_WEBHOOK_URL=https://your-gateway-domain.com/meta-webhook

# Token you choose when registering the webhook in Meta dashboard
WEBHOOK_VERIFY_TOKEN=choose_a_random_secret_string_here

# ── Shared MySQL database (same instance as ai-backend) ──────────────────────
DB_HOST=localhost
DB_USER=phixtra_user
DB_PASSWORD=your_db_password
DB_NAME=phixtra_db

# ── Phixtra AI backend ───────────────────────────────────────────────────────
# URL of the running ai-backend FastAPI service
AI_BACKEND_URL=http://127.0.0.1:8000

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8001
